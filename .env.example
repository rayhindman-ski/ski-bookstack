TZ=America/New_York
APP_URL=http://localhost:8090

# Generate with: docker run -it --rm --entrypoint /bin/bash lscr.io/linuxserver/bookstack:latest appkey
# Must be set BEFORE running docker compose up for the first time
APP_KEY=base64:your_generated_app_key_here

DB_DATABASE=bookstack
DB_USER=bookstack
DB_PASS=your_bookstack_db_password
DB_ROOT_PASS=your_mariadb_root_password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
TLS_ENCRYPTION=tls
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_ADDR=your_email@gmail.com
